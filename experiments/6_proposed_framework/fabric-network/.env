## =============================================================
##  Fabric Hierarchical Clustered FL — Environment Variables
## =============================================================

COMPOSE_PROJECT_NAME=fabricfl2
IMAGE_TAG=2.5
CA_IMAGETAG=1.5

## ── BankA CA credentials ──────────────────────────────────────
BANKA_CA_ADMIN_USER=admin
BANKA_CA_ADMIN_PASSWORD=adminpwBankA

## ── BankB CA credentials ──────────────────────────────────────
BANKB_CA_ADMIN_USER=admin
BANKB_CA_ADMIN_PASSWORD=adminpwBankB

## ── BankC CA credentials ──────────────────────────────────────
BANKC_CA_ADMIN_USER=admin
BANKC_CA_ADMIN_PASSWORD=adminpwBankC

## ── Orderer CA credentials ────────────────────────────────────
ORDERER_CA_ADMIN_USER=admin
ORDERER_CA_ADMIN_PASSWORD=adminpwOrderer

## ── Fabric binary config path ────────────────────────────────
## UPDATE this to match your Fabric installation.
## This must point to the directory containing core.yaml and orderer.yaml
## Common locations:
##   ~/fabric-samples/config
##   ~/hyperledger/fabric/config
FABRIC_CFG_PATH="/media/fyp-group-18/1TB-Hard/FYP-Group18/experiments/6_proposed_framework/fabric-samples/config"

## ── Channel & chaincode defaults ─────────────────────────────
CHANNEL_NAME=fraud-detection-global
CHAINCODE_NAME=cbft-fl
CHAINCODE_VERSION=1.0
CHAINCODE_SEQUENCE=1
